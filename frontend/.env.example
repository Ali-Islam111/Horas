# Environment Variables
# انسخ هذا الملف إلى .env.local وغير القيم حسب جهازك

# Backend API URL
# زميلك يقدر يغير الرابط ده حسب جهازه
VITE_API_URL=http://localhost:8000

# إذا الـ Backend شغال على port مختلف، غيره هنا:
# VITE_API_URL=http://localhost:5000
# أو إذا على جهاز تاني في الشبكة:
# VITE_API_URL=http://192.168.1.100:8000
