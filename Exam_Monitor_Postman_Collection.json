{
    "info": {
        "_postman_id": "a1b2c3d4-e5f6-7890-1234-56789abcdef0",
        "name": "Horas Demo API",
        "description": "Postman collection for the Horas Demo FastAPI backend.\n\n**How to use:**\n1. Run 'Register' to create an account.\n2. Run 'Login' — the token is saved automatically as {{jwt_token}}.\n3. All protected requests use {{jwt_token}} automatically.\n\n**Google OAuth2:**\nOpen the 'Login with Google' URL in a browser — Postman cannot handle browser redirects.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://127.0.0.1:8000",
            "type": "string"
        },
        {
            "key": "jwt_token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "1. Authentication",
            "item": [
                {
                    "name": "Register (Create Account)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"full_name\": \"Professor X\",\n  \"role\": \"teacher\",\n  \"password\": \"strongpassword123\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        },
                        "description": "Create a new user account.\n\n**Body (JSON):**\n- `email` — must be unique\n- `full_name` — display name\n- `role` — `student` or `teacher` \n- `password` — plain text, will be hashed server-side"
                    },
                    "response": []
                },
                {
                    "name": "Login (Get Token)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "var jsonData = pm.response.json();",
                                    "if (jsonData.access_token) {",
                                    "    pm.collectionVariables.set(\"jwt_token\", jsonData.access_token);",
                                    "    console.log(\"✅ Token saved:\", jsonData.access_token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/x-www-form-urlencoded"
                            }
                        ],
                        "body": {
                            "mode": "urlencoded",
                            "urlencoded": [
                                {
                                    "key": "username",
                                    "value": "teacher@example.com",
                                    "description": "Your email address",
                                    "type": "text"
                                },
                                {
                                    "key": "password",
                                    "value": "strongpassword123",
                                    "type": "text"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        },
                        "description": "Login with email and password.\n\nThe JWT Bearer token is **automatically saved** to `{{jwt_token}}` for use in all protected requests."
                    },
                    "response": []
                }
            ]
        },
        {
            "name": "2. Teacher - Exam Management",
